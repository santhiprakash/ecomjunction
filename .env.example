
# Neon Database Configuration
DATABASE_URL=postgresql://user:password@your-neon-hostname.neon.tech/ecomjunction?sslmode=require
DATABASE_POOLED_URL=postgresql://user:password@your-neon-hostname.neon.tech/ecomjunction?sslmode=require&pgbouncer=true

# JWT Authentication
VITE_JWT_SECRET=your-secret-key-change-in-production-use-openssl-rand-base64-32

# API Keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# NeonDB Configuration (PostgreSQL)
VITE_NEON_DATABASE_URL=postgresql://user:password@your-neon-hostname.neon.tech/ecomjunction?sslmode=require

# Emailit Configuration (emailit.com)
EMAILIT_API_KEY=your_emailit_api_key_here
EMAILIT_FROM_EMAIL=notifications@example.com
EMAILIT_FROM_NAME=eComJunction

# Environment
VITE_ENV=development

# Application Settings
VITE_APP_NAME=eComJunction
VITE_APP_URL=http://localhost:8080
VITE_DOMAIN=localhost
VITE_PRODUCTION_URL=https://ecomjunction.vercel.app

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ADVANCED_FEATURES=false
VITE_ENABLE_EMAIL_NOTIFICATIONS=true
